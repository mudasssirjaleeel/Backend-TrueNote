generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────

enum Role {
  user
  admin
  staff
}

enum GrindOption {
  whole_bean
  espresso
  v60
  chemex
  french_press
}

enum PurchasePlan {
  one_time
  subscribe
}

enum CartItemType {
  coffee
  bean
}

enum DeliveryMethod {
  pickup
  delivery
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  out_for_delivery
  delivered
  cancelled
}

enum SubscriptionPlan {
  weekly
  biweekly
  monthly
}

enum SubscriptionStatus {
  active
  paused
  cancelled
}

enum ContactStatus {
  unread
  read
  replied
  archived
}

enum StaffRole {
  super_admin
  manager
  barista
  counter
  rider
}

enum Permission {
  // Dashboard
  view_dashboard

  // Orders
  view_orders
  update_order_status
  cancel_order
  view_all_orders

  // KDS
  view_kds
  advance_order_status
  recall_order

  // Menu & Products
  view_menu
  edit_menu
  toggle_availability

  // Beans
  view_beans
  edit_beans

  // Categories
  view_categories
  edit_categories

  // Banners
  view_banners
  edit_banners

  // Subscriptions
  view_subscriptions
  manage_subscriptions

  // Customers
  view_customers
  manage_customers
  view_loyalty
  adjust_loyalty_points

  // Reports
  view_reports
  export_reports

  // Staff
  view_staff
  invite_staff
  manage_staff_roles

  // Settings
  view_settings
  edit_settings
}

// ─────────────────────────────────────────
//  USER
// ─────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String?  @unique
  phone        String?  @unique
  avatarUrl    String?  @map("avatar_url")
  passwordHash String?  @map("password_hash")
  role         Role     @default(user)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  cartItems     CartItem[]
  orders        Order[]
  wishlistItems WishlistItem[]
  addresses     Address[]

  loyaltyPoints   LoyaltyPoint[]
  redemptions     Redemption[]
  userEarnActions UserEarnAction[]

  subscriptions Subscription[]

  staffRecord  Staff?  @relation("staffUser")
  invitedStaff Staff[] @relation("staffInviter")

  deviceTokens  DeviceToken[]
  notifications NotificationLog[]

  @@map("users")
}

model RolePermission {
  id         String     @id @default(uuid())
  role       StaffRole
  permission Permission

  @@unique([role, permission])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone])
  @@index([expiresAt])
  @@map("otps")
}

// ─────────────────────────────────────────
//  CATEGORY
// ─────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  label     String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  products Product[]

  @@map("categories")
}

// ─────────────────────────────────────────
//  PRODUCT
// ─────────────────────────────────────────

model Product {
  id          String   @id @default(uuid())
  name        String
  subtitle    String?
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?  @map("image_url")
  imageUrls   String[] @map("image_urls")
  isAvailable Boolean  @default(true) @map("is_available")

  prepTimeMinutes Int?    @map("prep_time_minutes")
  modifierGroups  Json?   @map("modifier_groups")
  isDailySpecial  Boolean @default(false) @map("is_daily_special")
  specialOrder    Int?    @map("special_order")
  availableFrom   String? @map("available_from")
  availableUntil  String? @map("available_until")

  categoryId String?  @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category      Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants      ProductVariant[]
  sizes         ProductSize[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  subscriptions Subscription[]

  @@map("products")
}

model ProductVariant {
  id        String  @id @default(uuid())
  name      String
  price     Decimal @db.Decimal(10, 2)
  productId String  @map("product_id")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variants")
}

model ProductSize {
  id        String  @id @default(uuid())
  label     String
  price     Decimal @db.Decimal(10, 2)
  productId String  @map("product_id")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_sizes")
}

// ─────────────────────────────────────────
//  BEAN
// ─────────────────────────────────────────

model Bean {
  id                   String   @id @default(uuid())
  name                 String
  origin               String
  roastLevel           String?
  process              String?
  tastingNotes         String?
  weight               String
  price                Decimal  @db.Decimal(10, 2)
  imageUrl             String?  @map("image_url")
  imageUrls            String[] @map("image_urls")
  description          String?
  isDark               Boolean  @default(false) @map("is_dark")
  isAvailable          Boolean  @default(true) @map("is_available")
  subscriptionEligible Boolean  @default(true) @map("subscription_eligible")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  grindOptions  BeanGrindOption[]
  purchasePlans BeanPurchasePlan[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  subscriptions Subscription[]

  @@map("beans")
}

model BeanGrindOption {
  id     String      @id @default(uuid())
  grind  GrindOption
  beanId String      @map("bean_id")

  bean          Bean           @relation(fields: [beanId], references: [id], onDelete: Cascade)
  cartItems     CartItem[]
  orderItems    OrderItem[]
  subscriptions Subscription[]

  @@unique([beanId, grind])
  @@map("bean_grind_options")
}

model BeanPurchasePlan {
  id          String       @id @default(uuid())
  plan        PurchasePlan
  discount    Decimal?     @db.Decimal(5, 2)
  description String?
  beanId      String       @map("bean_id")

  bean       Bean        @relation(fields: [beanId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([beanId, plan])
  @@map("bean_purchase_plans")
}

// ─────────────────────────────────────────
//  BANNER
// ─────────────────────────────────────────

model Banner {
  id         String   @id @default(uuid())
  imageUrl   String   @map("image_url")
  imageUrls  String[] @map("image_urls")
  linkTarget String?  @map("link_target")
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("banners")
}

// ─────────────────────────────────────────
//  CART
// ─────────────────────────────────────────

model CartItem {
  id        String       @id @default(uuid())
  type      CartItemType
  quantity  Int          @default(1)
  unitPrice Decimal      @map("unit_price") @db.Decimal(10, 2)
  userId    String       @map("user_id")

  productId String? @map("product_id")
  variantId String? @map("variant_id")
  sizeId    String? @map("size_id")
  beanId    String? @map("bean_id")
  grindId   String? @map("grind_id")
  planId    String? @map("plan_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)
  size    ProductSize?      @relation(fields: [sizeId], references: [id], onDelete: SetNull)
  bean    Bean?             @relation(fields: [beanId], references: [id], onDelete: SetNull)
  grind   BeanGrindOption?  @relation(fields: [grindId], references: [id], onDelete: SetNull)
  plan    BeanPurchasePlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@map("cart_items")
}

// ─────────────────────────────────────────
//  ORDER
// ─────────────────────────────────────────

model Order {
  id             String         @id @default(uuid())
  status         OrderStatus    @default(pending)
  deliveryMethod DeliveryMethod @map("delivery_method")
  total          Decimal        @db.Decimal(10, 2)
  estimatedTime  String?        @map("estimated_time")
  userId         String         @map("user_id")
  confirmedAt    DateTime?

  // Contact snapshot
  contactName  String @map("contact_name")
  contactPhone String @map("contact_phone")
  contactEmail String @map("contact_email")

  channel     String?   @map("channel")
  orderMode   String?   @map("order_mode")
  tableNumber Int?      @map("table_number")
  pickupTime  DateTime? @map("pickup_time")

  // Delivery address — inline, only filled for delivery orders
  addressLine     String? @map("address_line")
  addressCity     String? @map("address_city")
  addressProvince String? @map("address_province")
  addressPostal   String? @map("address_postal")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String       @id @default(uuid())
  type      CartItemType
  quantity  Int
  unitPrice Decimal      @map("unit_price") @db.Decimal(10, 2)
  orderId   String       @map("order_id")

  productId String? @map("product_id")
  variantId String? @map("variant_id")
  sizeId    String? @map("size_id")
  beanId    String? @map("bean_id")
  grindId   String? @map("grind_id")
  planId    String? @map("plan_id")

  order   Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)
  size    ProductSize?      @relation(fields: [sizeId], references: [id], onDelete: SetNull)
  bean    Bean?             @relation(fields: [beanId], references: [id], onDelete: SetNull)
  grind   BeanGrindOption?  @relation(fields: [grindId], references: [id], onDelete: SetNull)
  plan    BeanPurchasePlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

// ─────────────────────────────────────────
//  WishlistItem
// ─────────────────────────────────────────

model WishlistItem {
  id        String       @id @default(uuid())
  type      CartItemType
  userId    String       @map("user_id")
  productId String?      @map("product_id")
  beanId    String?      @map("bean_id")
  createdAt DateTime     @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  bean    Bean?    @relation(fields: [beanId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@unique([userId, beanId])
  @@map("wishlist_items")
}

model Address {
  id         String   @id @default(uuid())
  label      String
  street     String
  city       String
  postalCode String   @map("postal_code")
  isDefault  Boolean  @default(false) @map("is_default")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ─────────────────────────────────────────
//  LOYALTY SYSTEM
// ─────────────────────────────────────────

model LoyaltyPoint {
  id        String   @id @default(uuid())
  points    Int
  userId    String   @map("user_id")
  source    String // e.g., "order", "review", "signup", "birthday", "redemption", "admin_adjustment"
  sourceId  String?  @map("source_id") // order_id, reward_id, or other reference
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("loyalty_points")
}

model Reward {
  id          String   @id @default(uuid())
  title       String
  description String?
  pointsCost  Int      @map("points_cost")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  redemptions Redemption[]

  @@map("rewards")
}

model Redemption {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  rewardId    String   @map("reward_id")
  pointsSpent Int      @map("points_spent")
  createdAt   DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rewardId])
  @@map("redemptions")
}

model EarnAction {
  id           String   @id @default(uuid())
  title        String
  pointsEarned Int      @map("points_earned")
  actionKey    String   @unique @map("action_key") // e.g., "first_order", "review_product", "birthday", "signup"
  maxPerUser   Int?     @default(1) @map("max_per_user")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userActions UserEarnAction[]

  @@map("earn_actions")
}

model UserEarnAction {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  earnActionId String   @map("earn_action_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  earnAction EarnAction @relation(fields: [earnActionId], references: [id], onDelete: Cascade)

  @@unique([userId, earnActionId])
  @@index([userId])
  @@index([earnActionId])
  @@map("user_earn_actions")
}

// ─────────────────────────────────────────
//  SUBSCRIPTIONS
// ─────────────────────────────────────────

model Subscription {
  id               String             @id @default(uuid())
  userId           String             @map("user_id")
  productId        String?            @map("product_id")
  beanId           String?            @map("bean_id")
  grindOptionId    String?            @map("grind_option_id")
  deliveryPlan     SubscriptionPlan   @map("delivery_plan")
  nextDeliveryDate DateTime           @map("next_delivery_date")
  price            Decimal            @db.Decimal(10, 2)
  status           SubscriptionStatus @default(active)
  cancelledAt      DateTime?          @map("cancelled_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  bean        Bean?            @relation(fields: [beanId], references: [id], onDelete: SetNull)
  grindOption BeanGrindOption? @relation(fields: [grindOptionId], references: [id], onDelete: SetNull)

  @@map("subscriptions")
}

// ─────────────────────────────────────────
//  CONTACT FORM
// ─────────────────────────────────────────

model ContactSubmission {
  id        String        @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  status    ContactStatus @default(unread)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("contact_submissions")
}

// ─────────────────────────────────────────
//  STAFF MANAGEMENT
// ─────────────────────────────────────────

model Staff {
  id         String    @id @default(uuid())
  userId     String    @unique @map("user_id")
  role       StaffRole @default(barista)
  invitedBy  String?   @map("invited_by")
  isActive   Boolean   @default(true) @map("is_active")
  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastActive DateTime? @map("last_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  user    User  @relation("staffUser", fields: [userId], references: [id], onDelete: Cascade)
  inviter User? @relation("staffInviter", fields: [invitedBy], references: [id])

  // Audit logs
  auditLogs StaffAuditLog[]

  @@map("staff")
}

model StaffAuditLog {
  id         String   @id @default(uuid())
  staffId    String   @map("staff_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relation
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([createdAt])
  @@map("staff_audit_logs")
}

// ─────────────────────────────────────────
//  NOTIFICATION SYSTEM
// ─────────────────────────────────────────

model DeviceToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  token      String   @unique
  deviceType String   @map("device_type") // ios, android, web
  deviceName String?  @map("device_name")
  appVersion String?  @map("app_version")
  isActive   Boolean  @default(true)
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("device_tokens")
}

model NotificationLog {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  title       String
  body        String
  type        String // order_status, subscription, payment, promotion, system
  data        Json? // Additional data (orderId, etc.)
  isRead      Boolean   @default(false)
  sentAt      DateTime  @default(now()) @map("sent_at")
  readAt      DateTime? @map("read_at")
  deliveredAt DateTime? @map("delivered_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([sentAt])
  @@map("notification_logs")
}

model EmailLog {
  id      String   @id @default(uuid())
  userId  String?  @map("user_id")
  email   String
  subject String
  type    String // order_confirmation, order_status, subscription, welcome, password_reset
  status  String // sent, failed, bounced
  error   String?
  sentAt  DateTime @default(now()) @map("sent_at")

  @@index([email])
  @@index([type])
  @@map("email_logs")
}
